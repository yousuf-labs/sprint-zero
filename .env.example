# Sprint Zero needs two values from a Supabase project you own.
# The free tier is fine. If you don't have one yet, create a project at
# https://supabase.com (takes about two minutes).
#
# Once your project is ready, open the Supabase dashboard and click
# Project Settings → API in the left sidebar. You'll see both values there.

# The URL of your Supabase project. Looks like https://abcxyz.supabase.co
# Found in: Project Settings → API → Project URL
SUPABASE_URL=

# The public "anon" key for your project. It's safe to use in client-side code.
# Found in: Project Settings → API → Project API keys → anon public
SUPABASE_ANON_KEY=
