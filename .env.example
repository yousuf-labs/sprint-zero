# Supabase project URL (Settings → API)
SUPABASE_URL=

# Supabase publishable key (formerly "anon key"). Safe to expose client-side.
# Find it under Project Settings → API Keys (the new tab, not Legacy).
SUPABASE_PUBLISHABLE_KEY=

# Supabase secret key (formerly "service_role key"). Server-side only, never ship to the client.
# Find it under Project Settings → API Keys. Click "Reveal" to see the value.
SUPABASE_SECRET_KEY=

# Supabase direct database URL — used by migrate.js to create tables automatically.
# Get it from: Supabase Dashboard → Settings → Database → Connection string → URI (Session mode, port 5432)
# It looks like: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
# You create and copy the password when you set up the database when creating the Supabase project. 
DATABASE_URL=